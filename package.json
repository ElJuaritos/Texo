{
  "name": "texo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@texo/web",
    "dev:mobile": "turbo run dev --filter=@texo/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "seed:demo": "node scripts/seed-demo.mjs",
    "build:static:web": "node scripts/prepare-static-export.mjs && npm run build --workspace=@texo/web && node scripts/restore-static-export.mjs"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "expo-font": "~14.0.12"
  },
  "packageManager": "npm@10.9.0"
}
